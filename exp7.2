#include <iostream>
#include<vector>
#include<algorithm>
using namespace std;

int main() {
    vector<int> v = {5, 3, 8, 1, 2};
    int n = v.size();

    for(int i = 0; i < n-1; i++) {
        for(int j = 0; j < n-i-1; j++) {
            if(v[j] > v[j+1]) {
                swap(v[j], v[j+1]); 
            }
        }
    }

    for(int x : v)
        cout << x << " ";

    return 0;
}
