#include <iostream>
#include<vector>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    vector<int> hashTable(m, -1);

    for(int i = 0; i < n; i++) {
        int x;
        cin >> x;

        int index = x % m;
        hashTable[index] = x; 
    }

    for(int i = 0; i < m; i++) {
        cout << i << ": " << hashTable[i] << endl;
    }
}
