#include <iostream>
#include<vector>
using namespace std;

void generate(vector<int> &arr, int idx) {
    if (idx == arr.size()) {
        for (int x : arr) cout << x << " ";
        cout << endl;
        return;
    }

    for (int i = idx; i < arr.size(); i++) {
        swap(arr[i], arr[idx]);
        generate(arr, idx + 1);
        swap(arr[i], arr[idx]); 
    }
}

int main() {
    int n;
    cin >> n;

    vector<int> arr(n);
    for (int i = 0; i < n; i++) cin >> arr[i];

    generate(arr, 0);
    return 0;
}
