#include <iostream>
#include<vector>
using namespace std;

int main() {
    int rows, cols;
    cin >> rows >> cols;

    vector<vector<int>> mat(rows, vector<int>(cols));

    for(int i = 0; i < rows; i++)
        for(int j = 0; j < cols; j++)
            cin >> mat[i][j];

    vector<vector<int>> transpose(cols, vector<int>(rows));

    for(int i = 0; i < rows; i++)
        for(int j = 0; j < cols; j++)
            transpose[j][i] = mat[i][j];

    cout << "Transpose:\n";
    for(auto &row : transpose) {
        for(auto val : row)
            cout << val << " ";
        cout << endl;
    }

    return 0;
}
