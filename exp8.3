#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

bool isAnagram(string s1, string s2) {
    if (s1.size() != s2.size()) return false;
    sort(s1.begin(), s1.end());
    sort(s2.begin(), s2.end());
    return s1 == s2;
}

int main() {
    string str1 = "listen";
    string str2 = "silent";
    cout << (isAnagram(str1, str2) ? "Anagram" : "Not Anagram") << endl;
    return 0;
}
