#include <iostream>
#include <string>
using namespace std;

int main() {
    string src = "hello world";
    string findstr = "world";

    size_t pos = src.find(findstr);
    if (pos != string::npos)
        cout << "Found at index " << pos << endl;
    else
        cout << -1 << endl;
    return 0;
}
