#include <iostream>
#include<vector>
using namespace std;

int main() {
    int n, target;
    cin >> n >> target;

    vector<int> arr(n);
    for (int i = 0; i < n; i++) cin >> arr[i];

    vector<int> dp(target + 1, 0);
    dp[0] = 1;

    for (int i = 0; i < n; i++) {
        for (int j = target; j >= arr[i]; j--) {
            dp[j] += dp[j - arr[i]];
        }
    }

    cout << dp[target];
    return 0;
}
