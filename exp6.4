#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, x;
    cin >> n >> x;

    vector<int> arr(n);
    for (int i = 0; i < n; i++) cin >> arr[i];

    int left = 0, right = n - 1;
    bool found = false;

    while (left < right) {
        int sum = arr[left] + arr[right];

        if (sum == x) {
            cout << arr[left] << " " << arr[right];
            found = true;
            break;
        }
        else if (sum < x) left++;
        else right--;
    }

    if (!found) cout << "No Pair Found";

    return 0;
}
