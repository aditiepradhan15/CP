#include <iostream>
#include <queue>
using namespace std;

int main() {
    queue<int> q;
    int n, x;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements:\n";
    for (int i = 0; i < n; i++) {
        cin >> x;
        q.push(x);
    }

    int count = 0;
    queue<int> temp = q;

    while (!temp.empty()) {
        count++;
        temp.pop();
    }

    cout << "Size of Queue without using size(): " << count;

    return 0;
}
