#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> arr(n);

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    for(int i = 0; i < n; i++) {
        bool leader = true;

        for(int j = i + 1; j < n; j++) {
            if(arr[i] < arr[j]) {
                leader = false;
                break;
            }
        }

        if(leader) {
            cout << arr[i] << " ";
        }
    }

    return 0;
}
